{
  "@@locale": "en",

  "appTitle": "YouTogether",
  "@appTitle": {
    "description": "Application name shown in the OS task switcher and window title. Used by MaterialApp.title once the app shell exists."
  },

  "registerPageTitle": "Create your account",
  "@registerPageTitle": {
    "description": "AppBar title on the registration screen (F-A01-T5)."
  },

  "registerEmailLabel": "Email",
  "@registerEmailLabel": {
    "description": "Label for the email field on the registration form."
  },

  "registerPasswordLabel": "Password",
  "@registerPasswordLabel": {
    "description": "Label for the password field on the registration form."
  },

  "registerUsernameLabel": "Username",
  "@registerUsernameLabel": {
    "description": "Label for the username field on the registration form."
  },

  "registerSubmitButton": "Sign up",
  "@registerSubmitButton": {
    "description": "Submit button label on the registration form."
  },

  "registerLoginLinkLabel": "Already have an account? Log in",
  "@registerLoginLinkLabel": {
    "description": "Navigation link from RegisterPage to LoginPage."
  },

  "registerErrorServer": "This email may already be registered, or the server rejected the request. Please check your details and try again.",
  "@registerErrorServer": {
    "description": "SnackBar message for RegisterState.failure(ServerFailure). Deliberately generic per the Failure internationalisation convention (core/error/failures.dart) — never renders the raw ServerFailure.message."
  },

  "registerErrorNetwork": "No internet connection. Please check your network and try again.",
  "@registerErrorNetwork": {
    "description": "SnackBar message for RegisterState.failure(NetworkFailure)."
  },

  "registerErrorCache": "Your account was created, but we could not save your session on this device. Please log in manually.",
  "@registerErrorCache": {
    "description": "SnackBar message for RegisterState.failure(CacheFailure) — specific to register(), where a cache failure means the account was already created server-side before local token persistence failed (see AuthRepositoryImpl.register, F-A01-T2)."
  },

  "registerErrorGeneric": "Something went wrong. Please try again.",
  "@registerErrorGeneric": {
    "description": "Fallback SnackBar message for any other Failure subtype (AuthFailure, NotFoundFailure, FirebaseFailure) that register() is not expected to produce in practice, but which the exhaustive switch must still handle."
  },

  "loginPageTitle": "Log in",
  "@loginPageTitle": {
    "description": "AppBar title on the login screen (F-A02-T3)."
  },

  "loginEmailLabel": "Email",
  "@loginEmailLabel": {
    "description": "Label for the email field on the login form."
  },

  "loginPasswordLabel": "Password",
  "@loginPasswordLabel": {
    "description": "Label for the password field on the login form."
  },

  "loginSubmitButton": "Log in",
  "@loginSubmitButton": {
    "description": "Submit button label on the login form."
  },

  "loginRegisterLinkLabel": "Don't have an account? Sign up",
  "@loginRegisterLinkLabel": {
    "description": "Navigation link from LoginPage to RegisterPage."
  },

  "loginErrorAuth": "Invalid email or password.",
  "@loginErrorAuth": {
    "description": "SnackBar message for LoginState.failure(AuthFailure), i.e. HTTP 401. Deliberately generic and identical regardless of whether the email or the password was wrong (OWASP A07:2021)."
  },

  "loginErrorServer": "The server rejected the request. Please try again.",
  "@loginErrorServer": {
    "description": "SnackBar message for LoginState.failure(ServerFailure) — never renders the raw ServerFailure.message."
  },

  "loginErrorNetwork": "No internet connection. Please check your network and try again.",
  "@loginErrorNetwork": {
    "description": "SnackBar message for LoginState.failure(NetworkFailure)."
  },

  "loginErrorCache": "You are logged in, but we could not save your session on this device. Please try again.",
  "@loginErrorCache": {
    "description": "SnackBar message for LoginState.failure(CacheFailure) — a cache failure here means the credentials were valid server-side but local token persistence failed (see AuthRepositoryImpl.login, F-A02-T2)."
  },

  "loginErrorGeneric": "Something went wrong. Please try again.",
  "@loginErrorGeneric": {
    "description": "Fallback SnackBar message for any other Failure subtype (NotFoundFailure, FirebaseFailure) that login() is not expected to produce in practice, but which the exhaustive switch must still handle."
  },

  "profilePageTitle": "Profile",
  "@profilePageTitle": {
    "description": "AppBar title on the profile screen (F-A05-T1)."
  },

  "profileMemberSince": "Member since {date}",
  "@profileMemberSince": {
    "description": "Displays the account creation date on the profile screen.",
    "placeholders": {
      "date": {
        "type": "String"
      }
    }
  },

  "profileRoleRegistered": "Registered",
  "@profileRoleRegistered": {
    "description": "Role badge label for UserRole.registered."
  },

  "profileRoleGuest": "Guest",
  "@profileRoleGuest": {
    "description": "Role badge label for UserRole.guest."
  },

  "profileLogoutButton": "Log out",
  "@profileLogoutButton": {
    "description": "Logout button label on the profile screen."
  },

  "homeEmptyStateMessage": "No public rooms available right now. Be the first to create one!",
  "@homeEmptyStateMessage": {
    "description": "Displayed on HomePage when RoomState.loaded(rooms) has an empty list (F-R01-T3)."
  },

  "homeErrorMessage": "We couldn't load the room list. Please try again.",
  "@homeErrorMessage": {
    "description": "Displayed on HomePage for RoomState.failure(any Failure subtype). Deliberately generic per the Failure internationalisation convention — never renders the raw Failure.message."
  },

  "homeRetryButtonLabel": "Retry",
  "@homeRetryButtonLabel": {
    "description": "Retry button label shown alongside homeErrorMessage on HomePage."
  },

  "homeRoomCardMemberCount": "{count, plural, =0{No members} =1{1 member} other{{count} members}}",
  "@homeRoomCardMemberCount": {
    "description": "Member count shown on RoomCard (HomePage) and RoomDetailPage.",
    "placeholders": {
      "count": {
        "type": "int",
        "example": "3"
      }
    }
  },

  "createRoomPageTitle": "Create a room",
  "@createRoomPageTitle": {
    "description": "AppBar title on the room creation screen (F-R02-T3)."
  },

  "createRoomNameFieldLabel": "Room name",
  "@createRoomNameFieldLabel": {
    "description": "Label for the name field on the room creation form."
  },

  "createRoomDescriptionFieldLabel": "Description (optional)",
  "@createRoomDescriptionFieldLabel": {
    "description": "Label for the optional description field on the room creation form."
  },

  "createRoomIsPublicLabel": "Public room",
  "@createRoomIsPublicLabel": {
    "description": "Label for the isPublic switch on the room creation form. Defaults to true."
  },

  "createRoomSubmitButtonLabel": "Create room",
  "@createRoomSubmitButtonLabel": {
    "description": "Submit button label on the room creation form."
  },

  "createRoomNetworkErrorMessage": "No internet connection. Please check your network and try again.",
  "@createRoomNetworkErrorMessage": {
    "description": "SnackBar message for CreateRoomState.failure(NetworkFailure)."
  },

  "createRoomServerErrorMessage": "The server rejected the request. Please try again.",
  "@createRoomServerErrorMessage": {
    "description": "SnackBar message for CreateRoomState.failure(ServerFailure) — never renders the raw ServerFailure.message."
  },

  "createRoomAuthErrorMessage": "You must be signed in to create a room.",
  "@createRoomAuthErrorMessage": {
    "description": "SnackBar message for CreateRoomState.failure(AuthFailure)."
  },

  "createRoomNotFoundErrorMessage": "Something went wrong. Please try again.",
  "@createRoomNotFoundErrorMessage": {
    "description": "SnackBar message for CreateRoomState.failure(NotFoundFailure) — not expected in practice for a creation request, but the exhaustive switch must still handle it."
  },

  "createRoomGenericErrorMessage": "Something went wrong. Please try again.",
  "@createRoomGenericErrorMessage": {
    "description": "Fallback SnackBar message for any other Failure subtype (ValidationFailure reaching the SnackBar branch, CacheFailure, FirebaseFailure) that createRoom() is not expected to produce in practice, but which the exhaustive switch must still handle."
  },

  "roomDetailOwnerBadgeLabel": "Owner",
  "@roomDetailOwnerBadgeLabel": {
    "description": "Badge label shown on RoomDetailPage when the current authenticated user owns the room."
  },

  "roomDetailErrorMessage": "We couldn't load this room. Please try again.",
  "@roomDetailErrorMessage": {
    "description": "Displayed on RoomDetailPage for RoomDetailState.failure(any Failure subtype), including a non-existent or deleted room (NotFoundFailure). Deliberately generic — never renders the raw Failure.message."
  },

  "roomDetailRetryButtonLabel": "Retry",
  "@roomDetailRetryButtonLabel": {
    "description": "Retry button label shown alongside roomDetailErrorMessage on RoomDetailPage."
  },

  "roomDetailBackButtonTooltip": "Back to room list",
  "@roomDetailBackButtonTooltip": {
    "description": "Tooltip/semantic label for the back button on RoomDetailPage's AppBar, present in every state (loading, loaded, failure)."
  },

  "roomDetailBackButtonTooltip": "Back to room list",
  "@roomDetailBackButtonTooltip": {
    "description": "Tooltip for the back button in RoomDetailPage's AppBar (navigation via context.go, no automatic back arrow)."
  },

  "roomDetailEditButtonTooltip": "Edit room",
  "@roomDetailEditButtonTooltip": {
    "description": "Tooltip for the owner-only edit icon button in RoomDetailPage's AppBar (F-R03-T3)."
  },

  "editRoomPageTitle": "Edit room",
  "@editRoomPageTitle": {
    "description": "AppBar title on the room edit screen (F-R03-T3)."
  },

  "editRoomSubmitButtonLabel": "Save changes",
  "@editRoomSubmitButtonLabel": {
    "description": "Submit button label on the room edit form."
  },

  "editRoomNetworkErrorMessage": "No internet connection. Please check your network and try again.",
  "@editRoomNetworkErrorMessage": {
    "description": "SnackBar message for EditRoomState.failure(NetworkFailure)."
  },

  "editRoomServerErrorMessage": "The server rejected the request. Please try again.",
  "@editRoomServerErrorMessage": {
    "description": "SnackBar message for EditRoomState.failure(ServerFailure) — never renders the raw ServerFailure.message."
  },

  "editRoomAuthErrorMessage": "Only the room owner can make this change.",
  "@editRoomAuthErrorMessage": {
    "description": "SnackBar message for EditRoomState.failure(AuthFailure), i.e. a 403 from a non-owner request that reached the cubit despite the edit button being hidden for non-owners."
  },

  "editRoomNotFoundErrorMessage": "This room no longer exists.",
  "@editRoomNotFoundErrorMessage": {
    "description": "SnackBar message for EditRoomState.failure(NotFoundFailure) — the room was deleted between opening the edit form and submitting it."
  },

  "editRoomGenericErrorMessage": "Something went wrong. Please try again.",
  "@editRoomGenericErrorMessage": {
    "description": "Fallback SnackBar message for any other Failure subtype (ValidationFailure reaching the SnackBar branch, CacheFailure, FirebaseFailure) that updateRoom() is not expected to produce in practice, but which the exhaustive switch must still handle."
  },

  "roomDetailDeleteButtonTooltip": "Delete room",
  "@roomDetailDeleteButtonTooltip": {
    "description": "Tooltip for the owner-only delete icon button in RoomDetailPage's AppBar (F-R04-T3)."
  },

  "roomDetailDeleteConfirmTitle": "Delete this room?",
  "@roomDetailDeleteConfirmTitle": {
    "description": "Title of the AlertDialog shown before deleting a room."
  },

  "roomDetailDeleteConfirmMessage": "This will remove the room from the public listing. This action cannot be undone.",
  "@roomDetailDeleteConfirmMessage": {
    "description": "Body text of the deletion confirmation AlertDialog."
  },

  "roomDetailDeleteCancelButtonLabel": "Cancel",
  "@roomDetailDeleteCancelButtonLabel": {
    "description": "Cancel button label on the deletion confirmation AlertDialog."
  },

  "roomDetailDeleteConfirmButtonLabel": "Delete",
  "@roomDetailDeleteConfirmButtonLabel": {
    "description": "Confirm button label on the deletion confirmation AlertDialog."
  },

  "roomDetailDeleteErrorMessage": "We couldn't delete this room. Please try again.",
  "@roomDetailDeleteErrorMessage": {
    "description": "SnackBar message for DeleteRoomState.failure(any Failure subtype), including a 403 from a non-owner request that reached the cubit despite the delete button being hidden for non-owners. Deliberately generic — never renders the raw Failure.message."
  }
}
